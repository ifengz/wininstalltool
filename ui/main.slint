import {
    Button,
    CheckBox,
    LineEdit,
    ScrollView,
    StandardTableView,
    TextEdit,
} from "std-widgets.slint";

export struct UiAppRow {
    selected: bool,
    name: string,
    purpose: string,
    source: string,
    verification: string,
    install_method: string,
    path: string,
}

component PhaseRow inherits Rectangle {
    in property <string> label;
    in property <bool> done;
    height: 20px;

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: done ? "●" : "●";
            font-size: 12px;
            color: done ? #2f3437 : #d7d9dd;
            width: 18px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
        Text {
            text: label;
            font-size: 12px;
            color: done ? #2f3437 : #787774;
            vertical-alignment: center;
        }
    }
}

component SidebarSectionLabel inherits Text {
    in property <string> label;
    text: label;
    font-size: 11px;
    font-weight: 700;
    color: #787774;
    height: 16px;
    vertical-alignment: center;
}

component RowActionButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    width: 40px;
    height: 24px;
    border-radius: 3px;
    border-width: 1px;
    border-color: action-touch.pressed ? #a8a8a4 : #ddddda;
    background: action-touch.has-hover ? #ffffff : #fbfbfa;

    Text {
        text: root.text;
        font-size: 12px;
        color: #111111;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    action-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "WinInstallTool";
    width: 1180px;
    height: 760px;

    in-out property <string> install-root;
    in-out property <string> cache-root;
    in property <string> task-status;
    in property <float> task-progress;
    in property <int> selected-count;
    in property <int> admin-count;
    in property <int> verification-count;
    in property <bool> all-visible-selected;
    in property <[string]> category-labels;
    in property <[TableColumn]> table-columns;
    in property <[[StandardListViewItem]]> table-rows;
    in property <[UiAppRow]> app-rows;
    in-out property <int> current-row: -1;
    in property <string> log-text;
    in property <bool> delete-confirm-visible;
    in property <string> delete-confirm-text;
    in property <bool> add-form-visible;
    in-out property <string> add-app-id;
    in-out property <string> add-app-name;
    in-out property <string> add-app-category;
    in-out property <string> add-app-winget-id;
    in-out property <string> add-app-homepage;
    in-out property <string> add-app-detect-path;

    callback choose-install-root();
    callback choose-cache-root();
    callback open-cache-root();
    callback open-homepage();
    callback start-install();
    callback download-cache();
    callback validate-config();
    callback detect-installed();
    callback show-add-app-form();
    callback show-edit-current-app-form();
    callback save-add-app-form();
    callback cancel-add-app-form();
    callback open-config();
    callback reload-config();
    callback request-delete-current-app();
    callback confirm-delete-current-app();
    callback cancel-delete-current-app();
    callback open-log();
    callback clear-log();
    callback export-log();
    callback category-selected(int);
    callback toggle-row-selection(int);
    callback toggle-visible-selection();
    callback open-row-homepage(int);
    callback show-edit-row-form(int);
    callback request-delete-row(int);

    background: #f7f6f3;

    Rectangle {
        width: root.width;
        height: root.height;
        background: #f7f6f3;

        Rectangle {
            x: 16px;
            y: 16px;
            width: 246px;
            height: root.height - 32px;
            border-radius: 3px;
            border-width: 1px;
            border-color: #e3e3df;
            background: #ffffff;

            VerticalLayout {
                padding: 16px;
                spacing: 6px;

                Text {
                    text: "Sinopin 软件安装";
                    font-size: 17px;
                    font-weight: 700;
                    color: #111111;
                    height: 28px;
                    vertical-alignment: center;
                }

                Rectangle { height: 8px; }

                SidebarSectionLabel { label: "执行"; }
                Button { text: "开始安装"; height: 28px; clicked => { root.start-install(); } }
                Button { text: "仅下载缓存"; height: 28px; clicked => { root.download-cache(); } }

                Rectangle { height: 4px; }

                SidebarSectionLabel { label: "软件管理"; }
                Button { text: "添加软件"; height: 28px; clicked => { root.show-add-app-form(); } }

                Rectangle { height: 4px; }

                SidebarSectionLabel { label: "配置工具"; }
                Button { text: "检查清单"; height: 28px; clicked => { root.validate-config(); } }
                Button { text: "扫描已安装"; height: 28px; clicked => { root.detect-installed(); } }
                Button { text: "打开清单文件"; height: 28px; clicked => { root.open-config(); } }
                Button { text: "重新读取清单"; height: 28px; clicked => { root.reload-config(); } }

                Text {
                    text: "非 Windows 会阻止真实安装";
                    font-size: 12px;
                    color: #787774;
                    height: 22px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Rectangle { height: 8px; }

                PhaseRow { label: "配置读取"; done: true; }
                PhaseRow { label: "安装计划预览"; done: true; }
                PhaseRow { label: "真实安装执行"; done: false; }
                PhaseRow { label: "驱动安装"; done: false; }

                Rectangle { vertical-stretch: 1; }
            }
        }

        VerticalLayout {
            x: 274px;
            y: 16px;
            width: root.width - 290px;
            height: root.height - 32px;
            spacing: 12px;

            Rectangle {
                border-radius: 3px;
                border-width: 1px;
                border-color: #e3e3df;
                background: #ffffff;
                clip: true;
                horizontal-stretch: 1;
                vertical-stretch: 1;

                VerticalLayout {
                    padding-left: 16px;
                    padding-top: 16px;
                    padding-right: 28px;
                    padding-bottom: 16px;
                    spacing: 10px;

                    HorizontalLayout {
                        height: 32px;
                        spacing: 10px;

                        Text {
                            text: "软件列表";
                            font-size: 13px;
                            font-weight: 700;
                            color: #111111;
                            width: 86px;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "默认安装路径";
                            font-size: 13px;
                            color: #787774;
                            width: 78px;
                            vertical-alignment: center;
                        }

                        LineEdit {
                            text <=> root.install-root;
                            width: 300px;
                            height: 28px;
                        }

                        Button {
                            text: "选择...";
                            width: 60px;
                            height: 28px;
                            clicked => { root.choose-install-root(); }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: "已选 " + root.selected-count;
                            font-size: 13px;
                            color: #2f3437;
                            width: 54px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "需管理员 " + root.admin-count;
                            font-size: 13px;
                            color: #787774;
                            width: 70px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "待实测 " + root.verification-count;
                            font-size: 13px;
                            color: #787774;
                            width: 64px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }

                    HorizontalLayout {
                        height: 30px;
                        spacing: 10px;

                        Text {
                            text: "缓存目录";
                            font-size: 13px;
                            color: #787774;
                            width: 88px;
                            vertical-alignment: center;
                        }

                        LineEdit {
                            text <=> root.cache-root;
                            width: 420px;
                            height: 28px;
                        }

                        Button {
                            text: "选择...";
                            width: 66px;
                            height: 28px;
                            clicked => { root.choose-cache-root(); }
                        }

                        Button {
                            text: "打开";
                            width: 54px;
                            height: 28px;
                            clicked => { root.open-cache-root(); }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;
                        for category[index] in root.category-labels: Button {
                            text: category;
                            height: 26px;
                            clicked => { root.category-selected(index); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        clip: true;

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 0px;

                                Rectangle {
                                    height: 34px;
                                    background: #fafafa;

                                    HorizontalLayout {
                                        spacing: 0px;
                                        CheckBox {
                                            width: 44px;
                                            height: 34px;
                                            text: "";
                                            checked: root.all-visible-selected;
                                            toggled => { root.toggle-visible-selection(); }
                                        }
                                        Text { text: "软件"; width: 132px; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "作用"; width: 74px; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "来源"; horizontal-stretch: 2; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "验证"; width: 100px; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "安装"; width: 86px; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "路径"; width: 150px; font-size: 12px; color: #787774; vertical-alignment: center; }
                                        Text { text: "操作"; width: 132px; font-size: 12px; color: #787774; vertical-alignment: center; horizontal-alignment: center; }
                                    }
                                }

                                for row[index] in root.app-rows: Rectangle {
                                    height: 32px;
                                    background: row_hover.has-hover || root.current-row == index ? #f3f3f1 : #ffffff;
                                    clip: true;

                                    row_hover := TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => { root.current-row = index; }
                                    }

                                    HorizontalLayout {
                                        spacing: 0px;
                                        CheckBox {
                                            width: 44px;
                                            height: 32px;
                                            text: "";
                                            checked: row.selected;
                                            toggled => { root.toggle-row-selection(index); }
                                        }
                                        Text { text: row.name; width: 132px; font-size: 13px; color: #2f3437; vertical-alignment: center; }
                                        Text { text: row.purpose; width: 74px; font-size: 13px; color: #555555; vertical-alignment: center; }
                                        Text { text: row.source; horizontal-stretch: 2; font-size: 13px; color: #555555; vertical-alignment: center; }
                                        Text { text: row.verification; width: 100px; font-size: 13px; color: #555555; vertical-alignment: center; }
                                        Text { text: row.install_method; width: 86px; font-size: 13px; color: #2f3437; vertical-alignment: center; }
                                        Text { text: row.path; width: 150px; font-size: 13px; color: #555555; vertical-alignment: center; }

                                        HorizontalLayout {
                                            width: 132px;
                                            height: 32px;
                                            spacing: 4px;
                                            opacity: row_hover.has-hover || root.current-row == index ? 1 : 0;

                                            RowActionButton { text: "官网"; clicked => { root.open-row-homepage(index); } }
                                            RowActionButton { text: "编辑"; clicked => { root.show-edit-row-form(index); } }
                                            RowActionButton { text: "删除"; clicked => { root.request-delete-row(index); } }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: root.add-form-visible ? 242px : 186px;
                border-radius: 3px;
                border-width: 1px;
                border-color: #e3e3df;
                background: #ffffff;
                clip: true;
                horizontal-stretch: 1;

                VerticalLayout {
                    padding-left: 12px;
                    padding-top: 12px;
                    padding-right: 28px;
                    padding-bottom: 12px;
                    spacing: 8px;

                    HorizontalLayout {
                        height: 24px;
                        spacing: 10px;

                        Text {
                            text: "状态 / 日志";
                            font-size: 13px;
                            font-weight: 700;
                            color: #111111;
                            width: 86px;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.task-status;
                            font-size: 12px;
                            color: #787774;
                            width: 150px;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Button { text: "打开日志"; width: 72px; height: 24px; clicked => { root.open-log(); } }
                        Button { text: "清空"; width: 54px; height: 24px; clicked => { root.clear-log(); } }
                        Button { text: "导出"; width: 54px; height: 24px; clicked => { root.export-log(); } }
                    }

                    HorizontalLayout {
                        visible: root.delete-confirm-visible;
                        height: root.delete-confirm-visible ? 28px : 0px;
                        spacing: 8px;

                        Text {
                            text: root.delete-confirm-text;
                            font-size: 12px;
                            color: #c92a2a;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "确认删除";
                            width: 76px;
                            height: 24px;
                            clicked => { root.confirm-delete-current-app(); }
                        }

                        Button {
                            text: "取消";
                            width: 54px;
                            height: 24px;
                            clicked => { root.cancel-delete-current-app(); }
                        }
                    }

                    VerticalLayout {
                        visible: root.add-form-visible;
                        height: root.add-form-visible ? 58px : 0px;
                        spacing: 6px;

                        HorizontalLayout {
                            height: 26px;
                            spacing: 8px;

                            Text {
                                text: "添加软件";
                                font-size: 12px;
                                font-weight: 700;
                                width: 64px;
                                vertical-alignment: center;
                            }

                            LineEdit { text <=> root.add-app-id; placeholder-text: "id"; width: 120px; height: 24px; }
                            LineEdit { text <=> root.add-app-name; placeholder-text: "名称"; width: 130px; height: 24px; }
                            LineEdit { text <=> root.add-app-category; placeholder-text: "分类；新名称会新增"; width: 150px; height: 24px; }
                            LineEdit { text <=> root.add-app-winget-id; placeholder-text: "winget 包 ID"; width: 190px; height: 24px; }
                        }

                        HorizontalLayout {
                            height: 26px;
                            spacing: 8px;

                            Text {
                                text: "检测路径";
                                font-size: 12px;
                                width: 64px;
                                vertical-alignment: center;
                            }

                            LineEdit { text <=> root.add-app-detect-path; placeholder-text: "C:\\Program Files\\App\\app.exe"; width: 330px; height: 24px; }
                            LineEdit { text <=> root.add-app-homepage; placeholder-text: "官网，可空"; width: 250px; height: 24px; }
                            Rectangle { horizontal-stretch: 1; }
                            Button { text: "保存"; width: 54px; height: 24px; clicked => { root.save-add-app-form(); } }
                            Button { text: "取消"; width: 54px; height: 24px; clicked => { root.cancel-add-app-form(); } }
                        }
                    }

                    TextEdit {
                        text: root.log-text;
                        read-only: true;
                        min-height: 96px;
                        vertical-stretch: 1;
                    }
                }
            }
        }
    }
}
