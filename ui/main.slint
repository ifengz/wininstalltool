import {
    Button,
    LineEdit,
    ProgressIndicator,
    StandardTableView,
    TextEdit,
} from "std-widgets.slint";

component PhaseRow inherits Rectangle {
    in property <string> label;
    in property <bool> done;
    height: 22px;

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: done ? "●" : "●";
            font-size: 12px;
            color: done ? #2f3437 : #d7d9dd;
            width: 18px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
        Text {
            text: label;
            font-size: 12px;
            color: done ? #2f3437 : #787774;
            vertical-alignment: center;
        }
    }
}

export component AppWindow inherits Window {
    title: "WinInstallTool";
    width: 1180px;
    height: 760px;

    in-out property <string> install-root;
    in-out property <string> cache-root;
    in property <string> task-status;
    in property <float> task-progress;
    in property <int> selected-count;
    in property <int> admin-count;
    in property <int> verification-count;
    in property <[string]> category-labels;
    in property <[TableColumn]> table-columns;
    in property <[[StandardListViewItem]]> table-rows;
    in-out property <int> current-row: -1;
    in property <string> log-text;
    in property <bool> delete-confirm-visible;
    in property <string> delete-confirm-text;
    in property <bool> add-form-visible;
    in-out property <string> add-app-id;
    in-out property <string> add-app-name;
    in-out property <string> add-app-category;
    in-out property <string> add-app-winget-id;
    in-out property <string> add-app-homepage;
    in-out property <string> add-app-detect-path;

    callback choose-install-root();
    callback choose-cache-root();
    callback open-cache-root();
    callback open-homepage();
    callback start-install();
    callback download-cache();
    callback validate-config();
    callback detect-installed();
    callback show-add-app-form();
    callback save-add-app-form();
    callback cancel-add-app-form();
    callback open-config();
    callback reload-config();
    callback request-delete-current-app();
    callback confirm-delete-current-app();
    callback cancel-delete-current-app();
    callback open-log();
    callback clear-log();
    callback export-log();
    callback category-selected(int);
    callback toggle-row-selection(int);

    background: #f7f6f3;

    HorizontalLayout {
        padding: 16px;
        spacing: 12px;

        Rectangle {
            width: 246px;
            border-radius: 3px;
            border-width: 1px;
            border-color: #e3e3df;
            background: #ffffff;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Office Standard";
                    font-size: 17px;
                    font-weight: 700;
                    color: #111111;
                    height: 28px;
                    vertical-alignment: center;
                }

                Text {
                    text: "10 个优先软件，顺序执行并写日志";
                    font-size: 13px;
                    color: #787774;
                    height: 22px;
                    vertical-alignment: center;
                }

                Rectangle { height: 8px; }

                Button { text: "开始安装"; height: 30px; clicked => { root.start-install(); } }
                Button { text: "仅下载缓存"; height: 30px; clicked => { root.download-cache(); } }
                Button { text: "校验配置"; height: 30px; clicked => { root.validate-config(); } }
                Button { text: "检测已安装"; height: 30px; clicked => { root.detect-installed(); } }
                Button { text: "添加软件"; height: 30px; clicked => { root.show-add-app-form(); } }
                Button { text: "打开软件配置"; height: 30px; clicked => { root.open-config(); } }
                Button { text: "重载配置"; height: 30px; clicked => { root.reload-config(); } }
                Button {
                    text: "删除当前软件";
                    height: 30px;
                    enabled: root.current-row >= 0;
                    clicked => { root.request-delete-current-app(); }
                }

                Text {
                    text: "非 Windows 会阻止真实安装";
                    font-size: 12px;
                    color: #787774;
                    height: 24px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Rectangle { height: 8px; }

                PhaseRow { label: "配置读取"; done: true; }
                PhaseRow { label: "安装计划预览"; done: true; }
                PhaseRow { label: "真实安装执行"; done: false; }
                PhaseRow { label: "驱动安装"; done: false; }

                Rectangle { vertical-stretch: 1; }
            }
        }

        VerticalLayout {
            spacing: 12px;
            horizontal-stretch: 1;

            Rectangle {
                border-radius: 3px;
                border-width: 1px;
                border-color: #e3e3df;
                background: #ffffff;
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    HorizontalLayout {
                        height: 32px;
                        spacing: 10px;

                        Text {
                            text: "安装中心";
                            font-size: 20px;
                            font-weight: 700;
                            color: #111111;
                            width: 96px;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "默认安装路径";
                            font-size: 13px;
                            color: #787774;
                            width: 88px;
                            vertical-alignment: center;
                        }

                        LineEdit {
                            text <=> root.install-root;
                            width: 320px;
                            height: 28px;
                        }

                        Button {
                            text: "选择...";
                            width: 66px;
                            height: 28px;
                            clicked => { root.choose-install-root(); }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: "已选 " + root.selected-count;
                            font-size: 13px;
                            color: #2f3437;
                            width: 64px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "需管理员 " + root.admin-count;
                            font-size: 13px;
                            color: #787774;
                            width: 82px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "待实测 " + root.verification-count;
                            font-size: 13px;
                            color: #787774;
                            width: 74px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }

                    HorizontalLayout {
                        height: 30px;
                        spacing: 10px;

                        Text {
                            text: "缓存目录";
                            font-size: 13px;
                            color: #787774;
                            width: 88px;
                            vertical-alignment: center;
                        }

                        LineEdit {
                            text <=> root.cache-root;
                            width: 420px;
                            height: 28px;
                        }

                        Button {
                            text: "选择...";
                            width: 66px;
                            height: 28px;
                            clicked => { root.choose-cache-root(); }
                        }

                        Button {
                            text: "打开";
                            width: 54px;
                            height: 28px;
                            clicked => { root.open-cache-root(); }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;
                        for category[index] in root.category-labels: Button {
                            text: category;
                            height: 26px;
                            clicked => { root.category-selected(index); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            text: "切换选择";
                            width: 76px;
                            height: 26px;
                            enabled: root.current-row >= 0;
                            clicked => { root.toggle-row-selection(root.current-row); }
                        }
                        Button {
                            text: "打开官网";
                            width: 76px;
                            height: 26px;
                            enabled: root.current-row >= 0;
                            clicked => { root.open-homepage(); }
                        }
                    }

                    StandardTableView {
                        columns: root.table-columns;
                        rows: root.table-rows;
                        current-row <=> root.current-row;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        row-pointer-event(row, event, position) => {
                            if event.button == PointerEventButton.left && event.kind == PointerEventKind.down && position.x < 44px {
                                root.toggle-row-selection(row);
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 186px;
                border-radius: 3px;
                border-width: 1px;
                border-color: #e3e3df;
                background: #ffffff;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    HorizontalLayout {
                        height: 24px;
                        spacing: 10px;

                        Text {
                            text: "状态 / 日志";
                            font-size: 13px;
                            font-weight: 700;
                            color: #111111;
                            width: 86px;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.task-status;
                            font-size: 12px;
                            color: #787774;
                            width: 210px;
                            vertical-alignment: center;
                        }

                        ProgressIndicator {
                            progress: root.task-progress;
                            indeterminate: false;
                            height: 8px;
                            horizontal-stretch: 1;
                        }

                        Button { text: "打开日志"; width: 72px; height: 24px; clicked => { root.open-log(); } }
                        Button { text: "清空"; width: 54px; height: 24px; clicked => { root.clear-log(); } }
                        Button { text: "导出"; width: 54px; height: 24px; clicked => { root.export-log(); } }
                    }

                    HorizontalLayout {
                        visible: root.delete-confirm-visible;
                        height: 28px;
                        spacing: 8px;

                        Text {
                            text: root.delete-confirm-text;
                            font-size: 12px;
                            color: #2f3437;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "确认删除";
                            width: 76px;
                            height: 24px;
                            clicked => { root.confirm-delete-current-app(); }
                        }

                        Button {
                            text: "取消";
                            width: 54px;
                            height: 24px;
                            clicked => { root.cancel-delete-current-app(); }
                        }
                    }

                    VerticalLayout {
                        visible: root.add-form-visible;
                        spacing: 6px;

                        HorizontalLayout {
                            height: 26px;
                            spacing: 8px;

                            Text {
                                text: "添加软件";
                                font-size: 12px;
                                font-weight: 700;
                                width: 64px;
                                vertical-alignment: center;
                            }

                            LineEdit { text <=> root.add-app-id; placeholder-text: "id"; width: 120px; height: 24px; }
                            LineEdit { text <=> root.add-app-name; placeholder-text: "名称"; width: 150px; height: 24px; }
                            LineEdit { text <=> root.add-app-category; placeholder-text: "分类"; width: 110px; height: 24px; }
                            LineEdit { text <=> root.add-app-winget-id; placeholder-text: "winget 包 ID"; width: 190px; height: 24px; }
                        }

                        HorizontalLayout {
                            height: 26px;
                            spacing: 8px;

                            Text {
                                text: "检测路径";
                                font-size: 12px;
                                width: 64px;
                                vertical-alignment: center;
                            }

                            LineEdit { text <=> root.add-app-detect-path; placeholder-text: "C:\\Program Files\\App\\app.exe"; width: 330px; height: 24px; }
                            LineEdit { text <=> root.add-app-homepage; placeholder-text: "官网，可空"; width: 250px; height: 24px; }
                            Rectangle { horizontal-stretch: 1; }
                            Button { text: "保存"; width: 54px; height: 24px; clicked => { root.save-add-app-form(); } }
                            Button { text: "取消"; width: 54px; height: 24px; clicked => { root.cancel-add-app-form(); } }
                        }
                    }

                    TextEdit {
                        text: root.log-text;
                        read-only: true;
                        vertical-stretch: 1;
                    }
                }
            }
        }
    }
}
